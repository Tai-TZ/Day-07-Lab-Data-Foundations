# Embedding (default: local MiniLM-L6-v2)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OpenRouter LLM (required for RAG answers)
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODELS=openai/gpt-4o-mini,google/gemini-2.5-flash,anthropic/claude-3.5-sonnet
OPENROUTER_MAX_TOKENS=1024
OPENROUTER_SITE_URL=http://localhost:8080
OPENROUTER_APP_NAME=RAG Workflow Studio

# Optional: ChromaDB persistence
# CHROMA_PERSIST_DIR=./chroma_data

# RAG Workflow Studio (frontend in studio/)
# VITE_RAG_API_URL=http://localhost:8000
# RAG_REVEAL_ORIGIN=http://localhost:5173
